#!/usr/bin/env python3
"""
Client for Claude Root Helper.
Usage: claude-root-cmd [--cwd DIR] [--timeout SECS] <command>
"""

import socket
import json
import sys
import os

SOCKET_PATH = '/var/run/claude-root-helper.sock'

def main():
    args = sys.argv[1:]
    cwd = os.getcwd()
    timeout = 120

    while args:
        if args[0] == '--cwd' and len(args) > 1:
            cwd = args[1]
            args = args[2:]
        elif args[0] == '--timeout' and len(args) > 1:
            timeout = int(args[1])
            args = args[2:]
        else:
            break

    if not args:
        print("Usage: claude-root-cmd [--cwd DIR] [--timeout SECS] <command>", file=sys.stderr)
        sys.exit(1)

    cmd = ' '.join(args)

    if not os.path.exists(SOCKET_PATH):
        print("Error: Root helper not running. Launch ClaudeRootHelper.app first.", file=sys.stderr)
        sys.exit(1)

    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.connect(SOCKET_PATH)
    except PermissionError:
        print("Error: Permission denied connecting to root helper socket.", file=sys.stderr)
        sys.exit(1)
    except ConnectionRefusedError:
        print("Error: Root helper not accepting connections. Relaunch the app.", file=sys.stderr)
        sys.exit(1)

    request = json.dumps({'command': cmd, 'cwd': cwd, 'timeout': timeout}) + '\n'
    sock.sendall(request.encode())
    sock.shutdown(socket.SHUT_WR)

    data = b''
    while True:
        chunk = sock.recv(65536)
        if not chunk:
            break
        data += chunk
    sock.close()

    response = json.loads(data.decode().strip())

    if response['stdout']:
        print(response['stdout'], end='')
    if response['stderr']:
        print(response['stderr'], end='', file=sys.stderr)

    sys.exit(response['exit_code'])

if __name__ == '__main__':
    main()
